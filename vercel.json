{
  "buildCommand": "pnpm build",
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "out/dist",
  "rewrites": [
    {
      "source": "/checkout/_next/:path*",
      "destination": "/_next/:path*"
    },
    {
      "source": "/checkout/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
